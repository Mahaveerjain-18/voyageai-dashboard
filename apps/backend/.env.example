# DUMMY environment variables for local development
# DO NOT commit this file to GitHub
# In production, use BuildWithLocus variables API:
# PUT /v1/variables/service/:serviceId

PORT=8080
NODE_ENV=development

# Locus Beta API
LOCUS_API_BASE=https://beta-api.paywithlocus.com/api
LOCUS_API_KEY=claw_dev_REPLACE_WITH_REAL_KEY

# Locus Wallet (from registration)
OWNER_PRIVATE_KEY=0xREPLACE_WITH_REAL_KEY
OWNER_ADDRESS=0xREPLACE_WITH_REAL_ADDRESS
WALLET_ID=REPLACE_WITH_REAL_WALLET_ID

# BuildWithLocus
BUILD_API_BASE=https://api.buildwithlocus.com
BUILD_TOKEN=REPLACE_WITH_JWT_TOKEN

# Frontend URL (auto-injected by .locusbuild in production)
FRONTEND_URL=http://localhost:3000
